  },
  "frameworks": [
    "arduino"
  ],
  "name": "nice!nano",
  "upload": {
    "maximum_ram_size": 248832,
    "maximum_size": 815104,
    "speed": 115200,
    "protocol": "nrfutil",
    "protocols": [
      "nrfutil",
      "jlink",
      "nrfjprog",
      "cmsis-dap",
      "blackmagic",
      "stlink"
    ],
    "use_1200bps_touch": true,
    "require_upload_port": true,
    "wait_for_upload_port": true
  },
  "url": "https://nicekeyboards.com/nice-nano",
  "vendor": "Nice Keyboards"
}
